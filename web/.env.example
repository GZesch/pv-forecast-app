# Lokale Entwicklung ohne Compose. Im Compose-Build werden die öffentlichen
# URLs aus SITE_ADDRESS und FORECAST_SITE_ADDRESS der Root-.env abgeleitet.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PV_FORECAST_URL=http://forecast.localhost

# Ausschließlich serverseitige FastAPI-Basisadresse.
BACKEND_API_BASE_URL=http://localhost:8000

# Serverseitiger Geocoder. Die URL bleibt austauschbar, ohne das Frontend zu ändern.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=ExergyPulse/1.0 (https://exergypulse.de)
