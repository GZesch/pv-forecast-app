# Für den ersten Test über die öffentliche Server-IP unverändert lassen.
# Für eine Domain später z. B. auf forecast.example.de setzen.
SITE_ADDRESS=:80

# Getrennte Adresse für die Next.js-Vorschau. Browser behandeln *.localhost
# üblicherweise lokal; falls der Windows-Resolver dies nicht tut, muss
# preview.localhost in der Hosts-Datei auf 127.0.0.1 gesetzt werden.
# Für ein Deployment eine eigene Preview-Domain verwenden.
# Diese URL wird beim Image-Build auch in Canonicals, Sitemap und robots.txt
# eingebettet. Änderungen erfordern daher einen Neubau des web-Images.
PREVIEW_SITE_ADDRESS=http://preview.localhost

# Öffentliche Adresse der bestehenden Streamlit-Anwendung. Der Link wird beim
# Build des Next.js-Frontends eingebettet; Änderungen erfordern einen Neubau.
PV_FORECAST_URL=http://localhost

# Nur serverseitig: FastAPI-Basisadresse für den PV-Wirtschaftlichkeitsrechner.
# Die Einbindung in Docker Compose folgt in AP7c.
BACKEND_API_BASE_URL=http://localhost:8000

# Keine Secrets erforderlich. Für Nominatim eine eigene Kontaktadresse ergänzen.
NOMINATIM_USER_AGENT="pv-forecast-app/1.0 (Kontakt: admin@example.de)"

OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_CACHE_TTL_SECONDS=21600
