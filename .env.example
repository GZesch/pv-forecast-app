# Öffentliche Adressen (Caddy und Buildzeit des Next.js-Images).
SITE_ADDRESS=http://exergypulse.localhost
FORECAST_SITE_ADDRESS=http://forecast.localhost

# Hostverzeichnis für externe Laufzeitdaten. Die H25-CSV nicht in Git einchecken.
BDEW_H25_DATA_HOST_DIR=./runtime-data

# Nur für lokale Next.js-Entwicklung ohne Compose. Im Compose-Webdienst wird
# BACKEND_API_BASE_URL fest auf http://backend:8000 gesetzt.
BACKEND_API_BASE_URL=http://localhost:8000

# Runtimewerte für bestehende Forecast-Dienste.
NOMINATIM_USER_AGENT="pv-forecast-app/1.0 (Kontakt: admin@example.de)"
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_CACHE_TTL_SECONDS=21600
